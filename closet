/* ═══════════════════════════════════════════
   AI PHOTO SCAN (New item modal enhancement)
═══════════════════════════════════════════ */
.scan-zone{border:2px dashed var(--border);border-radius:var(--r);min-height:120px;display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;transition:all .2s;position:relative;overflow:hidden;background:var(--surface)}
.scan-zone:hover{border-color:var(--purple);background:var(--purple-light)}
.scan-zone input{position:absolute;inset:0;opacity:0;cursor:pointer;width:100%;height:100%}
.scan-zone img{position:absolute;inset:0;width:100%;height:100%;object-fit:contain;background:var(--surface)}
.color-tag{display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:20px;font-size:11px;font-weight:600;cursor:default;transition:opacity .15s}
.color-tag .cx{cursor:pointer;opacity:.6;font-size:13px;margin-left:2px}
.color-tag .cx:hover{opacity:1}
.color-add-row{display:flex;gap:5px;margin-top:6px;align-items:center}
.color-add-row input[type=text]{flex:1;padding:6px 9px;border:1px solid var(--border);border-radius:var(--r);background:var(--surface);color:var(--ink);font-size:12px;outline:none}
.color-add-row input[type=text]:focus{border-color:var(--purple)}
.color-add-row input[type=color]{width:32px;height:32px;border:1px solid var(--border);border-radius:6px;cursor:pointer;padding:2px;background:var(--surface)}
.color-add-row select{padding:6px 7px;border:1px solid var(--border);border-radius:var(--r);background:var(--surface);color:var(--muted);font-size:11px;outline:none}
.color-add-row button{padding:6px 12px;background:var(--purple);color:#fff;border:none;border-radius:var(--r);font-size:11px;cursor:pointer;font-weight:600;white-space:nowrap}
.color-tags-wrap{display:flex;flex-wrap:wrap;gap:5px;padding:7px 9px;border:1px solid var(--border);border-radius:var(--r);background:var(--surface);min-height:36px;cursor:text}

/* ═══════════════════════════════════════════
   STATS
═══════════════════════════════════════════ */
.stats-wrap{padding:16px;max-width:1100px;width:100%;margin:0 auto}
.stats-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:12px}
.sc2{background:var(--card);border:1px solid var(--border);border-radius:var(--rl);padding:16px}
.sc2t{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:13px}
.brr{display:flex;align-items:center;gap:7px;margin-bottom:8px}
.brl{font-size:11px;width:70px;flex-shrink:0;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500}
.brt{flex:1;height:12px;background:var(--surface);border-radius:6px;overflow:hidden}
.brf{height:100%;border-radius:6px;transition:width .6s}
.brc{font-size:11px;font-weight:700;min-width:18px;text-align:right}

/* ═══════════════════════════════════════════
   MODALS
═══════════════════════════════════════════ */
.overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:500;align-items:flex-start;justify-content:center;padding:16px;overflow-y:auto;backdrop-filter:blur(2px)}
.overlay.open{display:flex}
.modal{background:var(--card);border-radius:var(--rxl);width:100%;max-width:560px;margin:auto;overflow:hidden;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.mhero{width:100%;height:180px;background:var(--surface);display:flex;align-items:center;justify-content:center;font-size:72px;overflow:hidden;position:relative}
.mhero img{width:100%;height:100%;object-fit:cover}
.mbody{padding:18px}
.mhead{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:11px}
.mtit{font-size:17px;font-weight:700}.msub2{font-size:12px;color:var(--muted);margin-top:2px;font-weight:500}
.mclose{background:none;border:none;font-size:22px;cursor:pointer;color:var(--muted);line-height:1;padding:2px;transition:color .15s}
.mclose:hover{color:var(--ink)}
.mtags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:12px}
.mt{padding:3px 10px;border-radius:20px;font-size:11px;font-weight:600}
.mtp{background:#F5F3FF;color:#5B21B6}.mtb{background:#EFF6FF;color:#1E40AF}.mtg{background:#F0FDF4;color:#166634}.mta{background:#FFFBEB;color:#92400E}.mtr{background:#FEF2F2;color:#991B1B}
.igrid{display:grid;grid-template-columns:1fr 1fr;border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:12px}
.ic{padding:8px 11px;border-bottom:1px solid var(--surface);border-right:1px solid var(--border)}
.ic:nth-child(even){border-right:none}
.ic:nth-last-child(-n+2){border-bottom:none}
.icl{font-size:10px;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;margin-bottom:2px;font-weight:600}
.icv{font-size:12px;font-weight:600}
.mmemo{background:var(--surface);border-radius:var(--r);padding:10px;font-size:12px;color:var(--muted);margin-bottom:12px;line-height:1.6;border:1px solid var(--border)}
.mlink{display:inline-flex;align-items:center;gap:4px;color:var(--purple);font-size:12px;margin-bottom:12px;font-weight:500}
.mfoot{display:flex;gap:7px;padding-top:12px;border-top:1px solid var(--surface)}
.mfb{flex:1;padding:9px;border-radius:var(--r);font-size:12px;cursor:pointer;font-weight:600;border:1px solid var(--border);background:transparent;color:var(--muted);transition:all .15s}
.mfb:hover{background:var(--surface)}
.mfb.p{background:var(--purple);color:#fff;border-color:var(--purple)}
.mfb.p:hover{background:var(--purple-dark)}
.mfb.d{color:var(--red);border-color:#FECACA}
.mfb.d:hover{background:#FEF2F2}
/* Add modal */
.am-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:600;align-items:flex-start;justify-content:center;padding:12px;overflow-y:auto;backdrop-filter:blur(2px)}
.am-overlay.open{display:flex}
.am{background:var(--card);border-radius:var(--rxl);width:100%;max-width:580px;padding:20px;margin:auto;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.am-head{font-size:16px;font-weight:700;margin-bottom:14px;display:flex;justify-content:space-between;align-items:center}
.am-x{background:none;border:none;font-size:22px;cursor:pointer;color:var(--muted);transition:color .15s}
.am-x:hover{color:var(--ink)}
.am-tabs{display:flex;gap:4px;margin-bottom:14px;padding:3px;background:var(--surface);border-radius:var(--r);border:1px solid var(--border)}
.am-tab{flex:1;padding:7px;border:none;background:transparent;border-radius:6px;cursor:pointer;font-size:12px;font-weight:600;color:var(--muted);transition:all .15s}
.am-tab.active{background:var(--card);color:var(--purple);box-shadow:0 1px 3px rgba(0,0,0,.1)}
.am-grid{display:grid;grid-template-columns:1fr 1fr;gap:9px}
.amfull{grid-column:1/-1}
.fg{display:flex;flex-direction:column;gap:3px}
.fg label{font-size:10px;color:var(--muted);font-weight:700;text-transform:uppercase;letter-spacing:.05em}
.fg input,.fg select,.fg textarea{padding:8px 10px;border:1px solid var(--border);border-radius:var(--r);background:var(--surface);color:var(--ink);font-size:12px;outline:none;width:100%;transition:border-color .15s;font-weight:500}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--purple)}
.fg textarea{resize:none;height:52px;line-height:1.5}
.am-foot{display:flex;gap:8px;margin-top:16px;justify-content:flex-end;padding-top:14px;border-top:1px solid var(--surface)}
.am-cancel{padding:8px 18px;border:1px solid var(--border);border-radius:var(--r);background:transparent;color:var(--muted);cursor:pointer;font-size:13px;font-weight:600}
.am-save{padding:8px 24px;background:var(--purple);color:#fff;border:none;border-radius:var(--r);font-size:13px;font-weight:700;cursor:pointer;transition:background .15s}
.am-save:hover{background:var(--purple-dark)}
/* AI scan tab */
.ai-result-badge{display:flex;align-items:center;gap:6px;padding:5px 12px;background:var(--purple-light);border:1px solid var(--purple-border);border-radius:20px;font-size:11px;color:#5B21B6;font-weight:600;margin-bottom:12px}
.conf-bar-row{display:flex;align-items:center;gap:8px;margin-bottom:12px}
.conf-label{font-size:11px;color:var(--muted);font-weight:500;white-space:nowrap}
.conf-track{flex:1;height:6px;background:var(--border);border-radius:3px;overflow:hidden}
.conf-fill{height:100%;border-radius:3px;background:var(--purple);transition:width .6s}
.conf-pct{font-size:11px;font-weight:700;color:var(--purple);min-width:30px;text-align:right}
.ai-note{background:var(--purple-light);border:1px solid var(--purple-border);border-radius:var(--r);padding:10px 12px;font-size:12px;line-height:1.7;color:#3730A3;margin-bottom:12px}
.ai-note-t{font-weight:700;font-size:11px;margin-bottom:3px;color:#5B21B6}
/* Picker */
.pk-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.55);z-index:700;align-items:center;justify-content:center;padding:16px;backdrop-filter:blur(2px)}
.pk-overlay.open{display:flex}
.pk-modal{background:var(--card);border-radius:var(--rxl);width:100%;max-width:500px;padding:16px;max-height:500px;display:flex;flex-direction:column;box-shadow:0 20px 60px rgba(0,0,0,.2)}
.pk-head{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;flex-shrink:0}
.pk-tit{font-size:15px;font-weight:700}
.pk-search{width:100%;padding:9px 11px;border:1px solid var(--border);border-radius:var(--r);background:var(--surface);color:var(--ink);font-size:13px;outline:none;margin-bottom:9px;flex-shrink:0}
.pk-search:focus{border-color:var(--purple)}
.pk-list{overflow-y:auto;flex:1;display:flex;flex-direction:column;gap:4px}
.pk-item{display:flex;align-items:center;gap:10px;padding:8px 10px;border-radius:var(--r);cursor:pointer;border:1px solid transparent;transition:all .12s}
.pk-item:hover{background:var(--surface)}
.pk-item.sel{background:var(--purple-light);border-color:var(--purple-border)}
.pk-thumb{width:36px;height:36px;border-radius:6px;background:var(--surface);display:flex;align-items:center;justify-content:center;font-size:16px;flex-shrink:0;overflow:hidden;border:1px solid var(--border)}
.pk-thumb img{width:100%;height:100%;object-fit:cover}
.pk-name{font-size:13px;font-weight:600;flex:1}
.pk-sub{font-size:11px;color:var(--muted);font-weight:500}
.pk-ck{color:var(--purple);font-size:16px;font-weight:700}

/* Responsive */
@media(max-width:640px){
  .home-grid{grid-template-columns:1fr}
  .weather-grid{grid-template-columns:repeat(4,1fr)}
  .stage-layout{grid-template-columns:1fr}
  .fit-wrap{flex-direction:column}
  .fit-left{width:100%;min-width:0;border-right:none;border-bottom:1px solid var(--border)}
  .am-grid{grid-template-columns:1fr}
  .stats-strip{grid-template-columns:repeat(2,1fr)}
}
</style>
</head>
