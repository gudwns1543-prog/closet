function getFiltered(){
  const q=(document.getElementById('searchQ').value||'').toLowerCase();
  const pm=Number(document.getElementById('pMin').value)||0,px=Number(document.getElementById('pMax').value)||Infinity;
  const sort=document.getElementById('ssort').value;
  let vCats=null;
  if(curSel!=='all'){if(GC[curSel])vCats=new Set(GC[curSel]);else vCats=new Set([curSel]);}
  let list=clothes.filter(c=>{
    if(vCats&&!vCats.has(c.cat))return false;
    const colorStr=(c.colors||[]).map(x=>x.name).join(' ');
    if(q&&![c.name,colorStr,c.brand,c.style,c.occasion,c.material,c.pattern,c.fit].join(' ').toLowerCase().includes(q))return false;
    if(filters.season.size&&!filters.season.has(c.season))return false;
    if(filters.material.size&&!filters.material.has(c.material))return false;
    if(filters.style.size&&!filters.style.has(c.style))return false;
    const p=Number(c.price)||0;if(pm&&p<pm)return false;if(px!==Infinity&&p>px)return false;
    return true;
  });
  if(sort==='newest')list.sort((a,b)=>(b.date||'').localeCompare(a.date||''));
  else if(sort==='oldest')list.sort((a,b)=>(a.date||'').localeCompare(b.date||''));
  else if(sort==='phi')list.sort((a,b)=>(Number(b.price)||0)-(Number(a.price)||0));
  else if(sort==='plo')list.sort((a,b)=>(Number(a.price)||0)-(Number(b.price)||0));
  else if(sort==='name')list.sort((a,b)=>a.name.localeCompare(b.name));
  return list;
}

