function applyPreset(p){
  const PR={
    summer:{inner:{on:true,vol:1},shirt:{on:true,vol:1},knit:{on:false,vol:2},outer:{on:false,vol:2},bottom:{on:true,vol:1},shoes:{on:false,vol:1},acc:{on:false,vol:1}},
    fall:  {inner:{on:true,vol:1},shirt:{on:true,vol:2},knit:{on:true,vol:3},outer:{on:true,vol:2},bottom:{on:true,vol:2},shoes:{on:false,vol:2},acc:{on:false,vol:1}},
    winter:{inner:{on:true,vol:2},shirt:{on:true,vol:3},knit:{on:true,vol:4},outer:{on:true,vol:5},bottom:{on:true,vol:3},shoes:{on:false,vol:2},acc:{on:false,vol:1}},
    overfit:{inner:{on:true,vol:3},shirt:{on:true,vol:4},knit:{on:true,vol:5},outer:{on:true,vol:5},bottom:{on:true,vol:4},shoes:{on:false,vol:2},acc:{on:false,vol:1}},
  };
  const pr=PR[p];Object.keys(pr).forEach(id=>{layers[id].on=pr[id].on;layers[id].vol=pr[id].vol;});
