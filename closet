<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MyWardrobe AI — 스마트 옷장 관리</title>
<style>
/* ═══════════════════════════════════════════
   RESET & BASE
═══════════════════════════════════════════ */
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --purple:#7C3AED;--purple-dark:#6D28D9;--purple-light:#F5F3FF;--purple-border:#DDD6FE;
  --ink:#111827;--muted:#6B7280;--hint:#9CA3AF;
  --bg:#F9FAFB;--surface:#F3F4F6;--card:#FFFFFF;
  --border:#E5E7EB;--border2:#D1D5DB;
  --r:8px;--rl:12px;--rxl:16px;
  --green:#22C55E;--amber:#F59E0B;--red:#EF4444;--blue:#3B82F6;
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:var(--bg);color:var(--ink);font-size:13px;line-height:1.5;min-height:100vh}
button,input,select,textarea{font-family:inherit}
img{display:block;max-width:100%}
a{color:var(--purple);text-decoration:none}

/* ═══════════════════════════════════════════
   LAYOUT
═══════════════════════════════════════════ */
.app{display:flex;flex-direction:column;height:100vh;overflow:hidden}
.topbar{display:flex;align-items:center;gap:8px;padding:0 16px;height:52px;background:var(--card);border-bottom:1px solid var(--border);flex-shrink:0;z-index:100;box-shadow:0 1px 3px rgba(0,0,0,.06)}
.logo-btn{display:flex;align-items:center;gap:7px;background:none;border:none;cursor:pointer;padding:6px 8px;border-radius:var(--r);transition:background .15s}
.logo-btn:hover{background:var(--surface)}
.logo-icon{font-size:20px}
.logo-text{font-size:15px;font-weight:700;color:var(--purple);letter-spacing:-.3px}
.nav-tabs{display:flex;gap:2px;flex:1;padding:0 8px}
.nav-tab{padding:6px 16px;border-radius:var(--r);border:none;background:transparent;cursor:pointer;font-size:13px;color:var(--muted);font-weight:500;transition:all .15s;white-space:nowrap}
.nav-tab:hover{background:var(--surface);color:var(--ink)}
.nav-tab.active{background:var(--purple);color:#fff}
.btn-add{padding:7px 16px;background:var(--purple);color:#fff;border:none;border-radius:var(--r);font-size:13px;cursor:pointer;font-weight:600;white-space:nowrap;transition:background .15s}
.btn-add:hover{background:var(--purple-dark)}
.pages{flex:1;overflow:hidden;position:relative}
.page{display:none;height:100%;overflow-y:auto}
.page.active{display:flex;flex-direction:column}

/* ═══════════════════════════════════════════
   HOME PAGE
═══════════════════════════════════════════ */
.home-wrap{padding:20px;display:flex;flex-direction:column;gap:16px;max-width:1100px;width:100%;margin:0 auto}
.home-hero{background:linear-gradient(135deg,#7C3AED 0%,#4F46E5 60%,#0891B2 100%);border-radius:var(--rxl);padding:24px 28px;color:#fff;position:relative;overflow:hidden}
.hero-bg{position:absolute;right:20px;top:50%;transform:translateY(-50%);font-size:100px;opacity:.1;pointer-events:none;line-height:1}
.hero-date{font-size:12px;opacity:.8;margin-bottom:4px}
.hero-title{font-size:22px;font-weight:700;margin-bottom:3px}
.hero-sub{font-size:13px;opacity:.8}
.weather-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:8px}
.wcard{background:var(--card);border:1px solid var(--border);border-radius:var(--rl);padding:11px 8px;text-align:center;transition:transform .15s,border-color .15s}
.wcard:hover{transform:translateY(-2px);border-color:var(--purple-border)}
.wday{font-size:10px;color:var(--muted);margin-bottom:5px;font-weight:600;text-transform:uppercase;letter-spacing:.05em}
.wicon{font-size:24px;margin-bottom:3px}
.wtemp{font-size:13px;font-weight:600}
.wdesc{font-size:10px;color:var(--muted);margin-top:2px}
.home-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.hcard{background:var(--card);border:1px solid var(--border);border-radius:var(--rl);padding:16px}
.hcard-t{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:12px}
.brow{display:flex;justify-content:space-between;align-items:center;padding:6px 0;border-bottom:1px solid var(--surface);font-size:13px}
.brow:last-child{border-bottom:none}
.bval{font-weight:700;color:var(--purple)}
.ai-rec{background:var(--purple-light);border:1px solid var(--purple-border);border-radius:var(--r);padding:12px;font-size:13px;line-height:1.7;min-height:60px;color:#3730A3}
.news-item{display:flex;gap:9px;padding:8px 0;border-bottom:1px solid var(--surface);cursor:pointer;transition:opacity .15s}
.news-item:hover{opacity:.7}
.news-item:last-child{border-bottom:none}
.ndot{width:6px;height:6px;border-radius:50%;background:var(--purple);margin-top:5px;flex-shrink:0}
.ntext{font-size:12px;line-height:1.5;color:var(--ink)}
.ntime{font-size:10px;color:var(--muted);margin-top:2px}

/* ═══════════════════════════════════════════
   WARDROBE
═══════════════════════════════════════════ */
.wd-layout{display:flex;flex:1;min-height:0;overflow:hidden}
.sidebar{width:200px;min-width:200px;background:var(--card);border-right:1px solid var(--border);overflow-y:auto;transition:width .2s,min-width .2s;flex-shrink:0}
.sidebar.col{width:42px;min-width:42px;overflow:hidden}
.sb-head{display:flex;justify-content:flex-end;padding:8px 8px 6px;border-bottom:1px solid var(--surface)}
.sbtog{background:none;border:1px solid var(--border);border-radius:6px;width:26px;height:26px;cursor:pointer;display:flex;align-items:center;justify-content:center;color:var(--muted);flex-shrink:0;transition:all .15s}
.sbtog:hover{background:var(--surface);border-color:var(--purple);color:var(--purple)}
/* Tree nav */
.tp{display:flex;align-items:center;width:100%;background:none;border:none;cursor:pointer;padding:0}
.tpi{display:flex;align-items:center;gap:7px;padding:7px 10px;flex:1;border-radius:var(--r);margin:1px 5px;transition:background .12s}
.tp:hover .tpi{background:var(--surface)}
.tp.act .tpi{background:var(--purple-light)}
.tp.act .tlbl{color:var(--purple);font-weight:600}
.tico{font-size:15px;width:20px;text-align:center;flex-shrink:0}
.tlbl{font-size:12px;flex:1;text-align:left;white-space:nowrap;overflow:hidden;color:var(--ink)}
.tcnt{font-size:10px;color:var(--muted);background:var(--surface);padding:1px 6px;border-radius:20px;flex-shrink:0}
.tarr{font-size:9px;color:var(--muted);width:14px;text-align:center;flex-shrink:0;transition:transform .2s}
.tarr.open{transform:rotate(90deg)}
.sidebar.col .tlbl,.sidebar.col .tcnt,.sidebar.col .tarr{display:none}
.sidebar.col .tpi{padding:7px;justify-content:center}
.tch{overflow:hidden;max-height:0;transition:max-height .25s}
.tch.open{max-height:500px}
.sidebar.col .tch{display:none}
.tc{display:flex;align-items:center;gap:6px;padding:5px 10px 5px 32px;cursor:pointer;border-radius:var(--r);margin:1px 5px;color:var(--muted);font-size:11px;transition:all .12s}
.tc:hover{background:var(--surface);color:var(--ink)}
.tc.act{background:#EDE9FE;color:var(--purple);font-weight:600}
.tc-cnt{font-size:10px;margin-left:auto;color:var(--muted)}
/* Wardrobe main */
.wd-main{flex:1;overflow-y:auto;padding:14px;min-width:0}
.stats-strip{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:8px;margin-bottom:12px}
.sbox{background:var(--card);border:1px solid var(--border);border-radius:var(--r);padding:11px 13px}
.sval{font-size:20px;font-weight:700;color:var(--ink)}.slbl{font-size:10px;color:var(--muted);margin-top:1px;font-weight:500}
.qtabs{display:flex;gap:5px;overflow-x:auto;padding-bottom:3px;margin-bottom:10px;scrollbar-width:none}
.qtabs::-webkit-scrollbar{display:none}
.qt{display:flex;align-items:center;gap:4px;padding:5px 12px;border-radius:20px;border:1px solid var(--border);background:var(--card);cursor:pointer;font-size:12px;color:var(--muted);white-space:nowrap;flex-shrink:0;transition:all .15s;font-weight:500}
.qt:hover{border-color:var(--purple);color:var(--purple)}
.qt.act{background:var(--purple);border-color:var(--purple);color:#fff}
.fbar{display:flex;gap:7px;margin-bottom:10px;flex-wrap:wrap;align-items:center}
.sw{flex:1;min-width:150px;position:relative}
.sw input{width:100%;padding:8px 11px 8px 30px;border:1px solid var(--border);border-radius:var(--r);background:var(--card);color:var(--ink);font-size:13px;outline:none;transition:border-color .15s}
.sw input:focus{border-color:var(--purple)}
.sw-ico{position:absolute;left:9px;top:50%;transform:translateY(-50%);font-size:13px;color:var(--muted);pointer-events:none}
.fbtn{display:flex;align-items:center;gap:5px;padding:8px 12px;border:1px solid var(--border);border-radius:var(--r);background:var(--card);cursor:pointer;font-size:12px;color:var(--muted);font-weight:500;transition:all .15s;white-space:nowrap}
.fbtn:hover,.fbtn.act{border-color:var(--purple);color:var(--purple);background:var(--purple-light)}
.fbadge{background:var(--purple);color:#fff;border-radius:20px;padding:1px 6px;font-size:10px;font-weight:700}
.ssort{padding:8px 10px;border:1px solid var(--border);border-radius:var(--r);background:var(--card);color:var(--muted);font-size:12px;outline:none;cursor:pointer}
/* Filter panel */
.fp{background:var(--card);border:1px solid var(--border);border-radius:var(--rl);padding:14px;margin-bottom:10px;display:none}
.fp.open{display:block}
.fp-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px}
.fpg label{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;display:block;margin-bottom:5px}
.fpchips{display:flex;flex-wrap:wrap;gap:4px}
.fpc{padding:3px 10px;border-radius:20px;border:1px solid var(--border);background:transparent;font-size:11px;cursor:pointer;color:var(--muted);font-weight:500;transition:all .12s}
.fpc:hover{border-color:var(--purple);color:var(--purple)}
.fpc.on{background:var(--purple);border-color:var(--purple);color:#fff}
.prow{display:flex;gap:5px;align-items:center}
.prow input{width:78px;padding:6px 7px;border:1px solid var(--border);border-radius:var(--r);background:var(--surface);color:var(--ink);font-size:12px;outline:none}
.prow input:focus{border-color:var(--purple)}
.fp-acts{display:flex;justify-content:flex-end;gap:7px;margin-top:12px;padding-top:12px;border-top:1px solid var(--surface)}
.fp-reset{padding:5px 14px;border:1px solid var(--border);border-radius:var(--r);background:transparent;font-size:12px;cursor:pointer;color:var(--muted);font-weight:500}
.fp-done{padding:5px 16px;background:var(--purple);color:#fff;border:none;border-radius:var(--r);font-size:12px;cursor:pointer;font-weight:600}
.afrow{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:7px}
.afc{display:flex;align-items:center;gap:4px;padding:3px 9px;background:var(--purple-light);border-radius:20px;font-size:11px;color:#5B21B6;border:1px solid var(--purple-border);font-weight:500}
.afx{cursor:pointer;font-size:13px;opacity:.6}.afx:hover{opacity:1}
.rinfo{font-size:11px;color:var(--muted);margin-bottom:9px;font-weight:500}
/* Clothes grid */
.cgrid{display:grid;grid-template-columns:repeat(auto-fill,minmax(148px,1fr));gap:10px}
.ccard{background:var(--card);border:1px solid var(--border);border-radius:var(--rl);overflow:hidden;cursor:pointer;transition:all .18s}
.ccard:hover{border-color:var(--purple);transform:translateY(-3px);box-shadow:0 8px 24px rgba(124,58,237,.12)}
.cthumb{width:100%;height:130px;background:var(--surface);display:flex;align-items:center;justify-content:center;font-size:42px;position:relative;overflow:hidden}
.cthumb img{width:100%;height:100%;object-fit:cover}
.cbadge{position:absolute;top:7px;right:7px;padding:2px 7px;border-radius:20px;font-size:10px;font-weight:600}
.cn{background:#DCFCE7;color:#166534}.cg{background:#DBEAFE;color:#1E40AF}.cm{background:#FEF9C3;color:#854D0E}.co{background:#FEE2E2;color:#991B1B}
.cbody{padding:9px 11px}
.cname{font-size:12px;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;margin-bottom:4px}
.ctags{display:flex;flex-wrap:wrap;gap:2px;margin-bottom:4px}
.ctag{display:inline-block;padding:1px 6px;border-radius:20px;font-size:10px;font-weight:600}
.ts{background:#EFF6FF;color:#1E40AF}.tst{background:#FFF7ED;color:#92400E}.tm{background:#F0FDF4;color:#166534}
.cprice{font-size:11px;color:var(--muted);font-weight:500}
.cprice strong{color:var(--ink);font-size:12px}
/* color dots */
.color-dots{display:flex;gap:3px;margin-bottom:4px}
.cdot{width:10px;height:10px;border-radius:50%;border:1.5px solid rgba(0,0,0,.1);flex-shrink:0}
.empty-state{text-align:center;padding:50px 20px;color:var(--muted)}
.empty-state div:first-child{font-size:48px;margin-bottom:12px}

/* ═══════════════════════════════════════════
   FITTING PAGE
═══════════════════════════════════════════ */
.fit-wrap{display:flex;flex:1;min-height:0;overflow:hidden}
.fit-left{width:272px;min-width:272px;background:var(--card);border-right:1px solid var(--border);overflow-y:auto;padding:14px;flex-shrink:0}
.fit-right{flex:1;overflow-y:auto;padding:14px;display:flex;flex-direction:column;gap:12px;min-width:0}
.sec-t{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:9px;padding-bottom:7px;border-bottom:1px solid var(--surface)}
.sec{margin-bottom:16px}
.avbox{width:100%;height:150px;border:2px dashed var(--border);border-radius:var(--r);display:flex;flex-direction:column;align-items:center;justify-content:center;cursor:pointer;gap:6px;font-size:12px;color:var(--muted);position:relative;overflow:hidden;transition:all .15s}
.avbox:hover{border-color:var(--purple);background:var(--purple-light);color:var(--purple)}
.avbox img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.bfgrid{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:9px}
.bf{display:flex;flex-direction:column;gap:3px}
.bf label{font-size:10px;color:var(--muted);font-weight:600}
.bf input,.bf select{padding:6px 7px;border:1px solid var(--border);border-radius:6px;background:var(--surface);color:var(--ink);font-size:11px;outline:none;width:100%}
.bf input:focus,.bf select:focus{border-color:var(--purple)}
/* Layer zones */
.qpresets{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:10px}
.qpbtn{padding:4px 10px;border-radius:20px;border:1px solid var(--border);background:var(--surface);font-size:11px;cursor:pointer;color:var(--muted);font-weight:500;transition:all .15s}
.qpbtn:hover{border-color:var(--purple);color:var(--purple);background:var(--purple-light)}
.lzone{border:1px solid var(--border);border-radius:var(--r);overflow:hidden;margin-bottom:7px;transition:border-color .15s}
.lzone.act{border-color:var(--purple)}
.lzhead{display:flex;align-items:center;gap:6px;padding:7px 10px;background:var(--surface);cursor:pointer;user-select:none;transition:background .15s}
.lzhead:hover{background:#ede9fe}
.lzico{font-size:14px}
.lzlbl{font-size:11px;font-weight:600;flex:1}
.lzbadge{font-size:10px;padding:1px 6px;background:var(--purple);color:#fff;border-radius:20px;font-weight:600}
.lzarr{font-size:9px;color:var(--muted);transition:transform .2s}
.lzarr.open{transform:rotate(90deg)}
.lzbody{display:none;padding:8px;background:var(--card)}
.lzbody.open{display:block}
.vol-row{display:flex;align-items:center;gap:7px;padding:4px 2px 7px;border-bottom:1px solid var(--surface);margin-bottom:6px}
.vol-lbl{font-size:10px;color:var(--muted);width:30px;flex-shrink:0;font-weight:600}
.vol-sl{flex:1;accent-color:var(--purple)}
.vol-num{font-size:10px;font-weight:700;color:var(--purple);width:55px;text-align:right;flex-shrink:0}
.vpresets{display:flex;gap:3px;flex-wrap:wrap;margin-bottom:7px}
.vpbtn{padding:2px 8px;border-radius:20px;border:1px solid var(--border);background:transparent;font-size:10px;cursor:pointer;color:var(--muted);font-weight:500}
.vpbtn:hover{border-color:var(--purple);color:var(--purple)}
.lzitems{display:flex;flex-direction:column;gap:3px;margin-bottom:5px}
.lzitem{display:flex;align-items:center;gap:6px;padding:5px 7px;border-radius:6px;background:var(--surface);font-size:11px}
.lzname{flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-weight:500}
.lzord{font-size:10px;color:var(--muted);background:var(--card);padding:1px 5px;border-radius:20px;border:1px solid var(--border)}
.lzrm{background:none;border:none;cursor:pointer;font-size:14px;color:var(--muted);padding:0 2px;transition:color .15s}
.lzrm:hover{color:var(--red)}
.lzadd{width:100%;padding:5px;border:1px dashed var(--border);border-radius:var(--r);background:transparent;font-size:11px;cursor:pointer;color:var(--muted);font-weight:500;transition:all .15s}
.lzadd:hover{border-color:var(--purple);color:var(--purple);background:var(--purple-light)}
/* Stage */
.stage-card{background:var(--card);border:1px solid var(--border);border-radius:var(--rl);padding:14px;flex-shrink:0}
.stage-t{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:10px}
.stage-layout{display:grid;grid-template-columns:180px 1fr;gap:12px;min-height:340px}
.stage-person{background:var(--surface);border-radius:var(--r);overflow:hidden;position:relative;display:flex;align-items:center;justify-content:center;border:1px solid var(--border)}
.stage-person img{width:100%;height:100%;object-fit:cover}
.stage-ph{font-size:11px;color:var(--muted);text-align:center;padding:12px;line-height:1.7}
.stage-right{display:flex;flex-direction:column;gap:9px;min-width:0}
.sil-panel{background:var(--surface);border-radius:var(--r);padding:10px;border:1px solid var(--border)}
.sil-t{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.07em;margin-bottom:7px}
.sil-inner{display:flex;align-items:flex-start;gap:10px}
.vscore-row{display:flex;gap:8px;align-items:center;margin-bottom:5px}
.vscore-num{font-size:24px;font-weight:700;min-width:38px;color:var(--purple)}
.vscore-bar-wrap{flex:1}
.vscore-track{height:8px;background:var(--border);border-radius:4px;overflow:hidden;margin-bottom:3px}
.vscore-fill{height:100%;border-radius:4px;transition:width .4s,background .4s}
.vscore-lbl{font-size:11px;color:var(--muted);font-weight:500}
.verdict{padding:8px 10px;border-radius:var(--r);font-size:12px;line-height:1.6;font-weight:600;margin-bottom:5px}
.v-ok{background:#F0FDF4;color:#166534}.v-warn{background:#FFFBEB;color:#92400E}.v-bad{background:#FEF2F2;color:#991B1B}
.bd-row{display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid var(--surface);font-size:11px}
.bd-row:last-child{border-bottom:none}
.bv{font-weight:700}
.lv-wrap{background:var(--surface);border-radius:var(--r);padding:9px;flex:1;overflow-y:auto;border:1px solid var(--border)}
.lv-zone{border-radius:6px;overflow:hidden;border:1px solid var(--border);margin-bottom:6px}
.lv-zone:last-child{margin-bottom:0}
.lvzhead{padding:6px 9px;font-size:11px;font-weight:600;display:flex;align-items:center;gap:6px;flex-wrap:wrap}
.lvitems{display:flex;flex-wrap:wrap;gap:6px;padding:7px 9px}
.lvitem{display:flex;flex-direction:column;align-items:center;gap:3px;min-width:52px}
.lvthumb{width:48px;height:48px;border-radius:7px;background:var(--card);display:flex;align-items:center;justify-content:center;font-size:22px;overflow:hidden;border:1px solid var(--border);position:relative}
.lvthumb img{width:100%;height:100%;object-fit:cover}
.lvord{position:absolute;top:-4px;left:-4px;width:15px;height:15px;border-radius:50%;background:var(--purple);color:#fff;font-size:8px;display:flex;align-items:center;justify-content:center;font-weight:700}
.lvname{font-size:9px;color:var(--muted);text-align:center;max-width:52px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-weight:500}
.expose-tag{font-size:9px;padding:2px 7px;background:var(--purple-light);color:#5B21B6;border-radius:20px;border:1px solid var(--purple-border);font-weight:600;white-space:nowrap}
/* Controls */
.ctrl-row{display:flex;gap:7px;margin-top:10px;flex-wrap:wrap}
.cbtn{flex:1;min-width:88px;padding:8px;border:1px solid var(--border);border-radius:var(--r);background:var(--card);font-size:12px;cursor:pointer;color:var(--muted);font-weight:600;transition:all .15s}
.cbtn:hover{background:var(--surface);border-color:var(--purple);color:var(--purple)}
.cbtn.p{background:var(--purple);color:#fff;border-color:var(--purple)}
.cbtn.p:hover{background:var(--purple-dark)}
.cbtn:disabled{opacity:.5;cursor:not-allowed}
.airesult{background:var(--purple-light);border:1px solid var(--purple-border);border-radius:var(--r);padding:12px;font-size:13px;line-height:1.7;display:none;margin-top:10px;color:#3730A3}
.airesult.on{display:block}
/* SPIN */
.spin{display:inline-block;width:12px;height:12px;border:2px solid rgba(124,58,237,.2);border-top-color:var(--purple);border-radius:50%;animation:sp .7s linear infinite;vertical-align:middle;margin-right:5px}
