function setZoneVol(zid,v){
  layers[zid].vol=parseInt(v);
  const vn=document.getElementById('vn-'+zid);if(vn)vn.textContent=`${v}/5 · ${VL[parseInt(v)]}`;
  const sl=document.querySelector(`#lz-${zid} .vol-sl`);if(sl)sl.value=v;
  updateVolume();
}
function rmFromZone(zid,cid){layers[zid].items=layers[zid].items.filter(c=>c.id!==cid);renderLayerZones();}
function updateVolume(){
  const activeZ=LZ_DEF.filter(z=>layers[z.id].on||layers[z.id].items.length>0);
  const upperZ=activeZ.filter(z=>z.id!=='bottom'&&z.id!=='shoes'&&z.id!=='acc');
  const bottomZ=activeZ.find(z=>z.id==='bottom');
  const upperPx=upperZ.reduce((a,z)=>a+VPX[layers[z.id].vol],0);
  const bottomPx=bottomZ?VPX[layers[bottomZ.id].vol]:0;
  drawSilhouette(Math.min(upperPx,34),Math.min(bottomPx,17));
  drawVolBar(upperPx,bottomPx);
  calcScore(upperPx,bottomPx,upperZ,bottomZ);
  updateLVPanel(activeZ);
}
function drawSilhouette(ue,be){
  const cx=54,sw=22+ue,ww=17+ue*.6,hw=21+ue*.4+be*.2,aw=8+ue*.7,ao=sw+3;
  document.getElementById('sbody').setAttribute('d',`M${cx-sw} 47 Q${cx-sw-6} 51 ${cx-ww} 72 L${cx-hw} 117 Q${cx-hw} 121 ${cx} 121 Q${cx+hw} 121 ${cx+hw} 117 L${cx+ww} 72 Q${cx+sw+6} 51 ${cx+sw} 47 Z`);
  document.getElementById('sarml').setAttribute('d',`M${cx-sw} 55 Q${cx-ao-9} 62 ${cx-ao-11} 95 Q${cx-ao-12} 103 ${cx-ao-7} 105 Q${cx-ao-2} 107 ${cx-ao} 97 L${cx-sw+3} 68 Z`);
  document.getElementById('sarmr').setAttribute('d',`M${cx+sw} 55 Q${cx+ao+9} 62 ${cx+ao+11} 95 Q${cx+ao+12} 103 ${cx+ao+7} 105 Q${cx+ao+2} 107 ${cx+ao} 97 L${cx+sw-3} 68 Z`);
  const bw=14+be,tw=11+be*.5;
  document.getElementById('sbot').setAttribute('d',`M${cx-hw} 117 Q${cx-hw-1} 135 ${cx-bw-1} 170 Q${cx-bw-2} 179 ${cx-bw+6} 179 Q${cx-bw+14} 179 ${cx-bw+13} 170 L${cx-tw} 136 L${cx} 133 L${cx+tw} 136 L${cx+bw-13} 170 Q${cx+bw-14} 179 ${cx+bw-6} 179 Q${cx+bw+2} 179 ${cx+bw+1} 170 Q${cx+hw+1} 135 ${cx+hw} 117 Z`);
  document.getElementById('sfl').setAttribute('cx',cx-bw+3);
  document.getElementById('sfr').setAttribute('cx',cx+bw-3);
}
function drawVolBar(ue,be){
  const maxPx=VPX[5]*4,total=ue+be*.5,pct=Math.min(Math.round(total/maxPx*100),100);
  const bw=Math.round(pct/100*94);
  document.getElementById('sVolBar').setAttribute('width',Math.max(bw,0));
  document.getElementById('sVolPct').textContent=pct+'%';
  let st,col;
  if(pct<30){st='슬림';col='#22C55E';}else if(pct<55){st='적당';col='#7C3AED';}else if(pct<75){st='볼륨';col='#F59E0B';}else{st='과볼륨!';col='#EF4444';}
  document.getElementById('sVolBar').setAttribute('fill',col);
  document.getElementById('sVolSt').textContent=st;
}
function calcScore(ue,be,upperZ,bottomZ){
  const score=Math.min(Math.round((ue*2+be)*1.5),100);
  document.getElementById('vscoreNum').textContent=score;
  const fill=document.getElementById('vscoreFill');
  fill.style.width=score+'%';fill.style.background=score<30?'var(--green)':score<60?'var(--amber)':'var(--red)';
  let vt,vc;
  if(score<25){vt='✓ 슬림하고 깔끔한 실루엣이에요';vc='v-ok';}
  else if(score<50){vt='○ 적당한 볼륨감 — 체형에 따라 자연스러워요';vc='v-warn';}
  else if(score<72){vt='△ 볼륨 높음 — 두꺼운 레이어가 겹쳐있어요';vc='v-warn';}
  else{vt='⚠ 과볼륨! 심하게 부해 보일 수 있어요';vc='v-bad';}
  const vbox=document.getElementById('verdictBox');vbox.textContent=vt;vbox.className='verdict '+vc;
  let bdHtml='';
  for(let i=1;i<upperZ.length;i++){
    const a=upperZ[i-1],b=upperZ[i],lA=layers[a.id],lB=layers[b.id],conflict=lA.vol>=3&&lB.vol>=3;
    bdHtml+=`<div class="bd-row"><span>${a.lbl.split(' ')[0]} + ${b.lbl.split(' ')[0]}</span><span class="bv" style="color:${conflict?'var(--red)':'var(--green)'}">${conflict?'⚠ 두께 충돌':'✓ 양호'}</span></div>`;
  }
  const hasOuter=layers['outer'].on||layers['outer'].items.length>0;
  const hasKnit=layers['knit'].on||layers['knit'].items.length>0;
  const hasShirt=layers['shirt'].on||layers['shirt'].items.length>0;
  if(hasOuter&&hasKnit){bdHtml+=`<div class="bd-row"><span>아우터 착용 시 니트 소매</span><span class="bv" style="color:var(--purple)">${VPX[layers['knit'].vol]>6?'많이':'살짝'} 노출</span></div>`;}
  if(hasOuter&&hasShirt&&!hasKnit){bdHtml+=`<div class="bd-row"><span>아우터 안 상의 밑단</span><span class="bv" style="color:var(--purple)">${layers['shirt'].vol>=3?'많이':'살짝'} 비어져나옴</span></div>`;}
  document.getElementById('bdRows').innerHTML=bdHtml;
}
function updateLVPanel(activeZ){
  const lv=document.getElementById('lvWrap');
  if(!activeZ.length){lv.innerHTML='<div style="font-size:11px;color:var(--muted);text-align:center;padding:18px;font-weight:500">레이어를 추가하면 여기에 표시돼요</div>';return;}
  const order=['inner','shirt','knit','outer','bottom','shoes','acc'];
  lv.innerHTML=activeZ.sort((a,b)=>order.indexOf(a.id)-order.indexOf(b.id)).map(z=>{
    const L=layers[z.id];
    let exposeTag='';
    if(z.id==='outer'&&(layers['knit'].on||layers['knit'].items.length>0)){exposeTag=`<span class="expose-tag">니트 소매 ${VPX[layers['knit'].vol]>6?'많이':'살짝'} 노출</span>`;}
    if(z.id==='outer'&&(layers['shirt'].on||layers['shirt'].items.length>0)&&!layers['knit'].on&&!layers['knit'].items.length){exposeTag=`<span class="expose-tag">상의 밑단 노출</span>`;}
    const itemsHTML=L.items.map((c,i)=>{const ci=CF[c.cat]||{ico:'👚'};return`<div class="lvitem"><div class="lvthumb">${c.img?`<img src="${c.img}">`:`<span>${ci.ico}</span>`}<span class="lvord">${i+1}</span></div><div class="lvname">${c.name.slice(0,6)}</div></div>`;}).join('');
    const noItem=`<div class="lvitem"><div class="lvthumb" style="background:${z.bg};border-color:${z.color}"><span style="font-size:20px">${z.ico}</span></div><div class="lvname">두께${L.vol}</div></div>`;
    return`<div class="lv-zone" style="border-color:${z.color}"><div class="lvzhead" style="background:${z.bg}"><span>${z.ico}</span><span>${z.lbl}</span><span style="font-size:10px;color:var(--muted);margin-left:4px">두께 ${L.vol}/5</span>${exposeTag}</div><div class="lvitems">${L.items.length?itemsHTML:noItem}</div></div>`;
  }).join('');
}
function renderFitStage(){if(avData)document.getElementById('stagePerson').innerHTML=`<img src="${avData}">`;updateVolume();}
function loadAv(e){const f=e.target.files[0];if(!f)return;const r=new FileReader();r.onload=ev=>{avData=ev.target.result;document.getElementById('avbox').innerHTML=`<img src="${avData}"><input type="file" id="avfile" accept="image/*" style="display:none" onchange="loadAv(event)">`};r.readAsDataURL(f);}
async function runLayerAI(){
  const btn=document.getElementById('aiBtn'),box=document.getElementById('aiResult');
  btn.disabled=true;box.className='airesult on';box.innerHTML='<span class="spin"></span>레이어드 볼륨을 분석 중...';
  const activeZ=LZ_DEF.filter(z=>layers[z.id].on||layers[z.id].items.length>0);
  const h=document.getElementById('bH').value,sh=document.getElementById('bSh').value;
  let prompt=`전문 패션 스타일리스트로서 레이어드 코디를 분석해주세요.\n\n`;
  if(h||sh)prompt+=`[체형] 키:${h||'-'}cm, ${sh||'-'}\n\n`;
  prompt+=`[레이어 구성]\n`;
  activeZ.forEach(z=>{const L=layers[z.id];const items=L.items.map(c=>c.name).join(',');prompt+=`- ${z.lbl}: 두께 ${L.vol}/5(${VL[L.vol]})${items?` — ${items}`:''}\n`;});
  prompt+=`\n분석(300자 내외):\n1) 전체 실루엣\n2) 두께 충돌 여부\n3) 아우터 착용 시 소매·밑단 노출\n4) 체형별 조언\n5) 개선 제안`;
  try{
    const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:600,messages:[{role:'user',content:prompt}]})});
    const data=await res.json();box.innerHTML=data.content.map(c=>c.text||'').join('').replace(/\n/g,'<br>');
  }catch(e){box.innerHTML='오류: '+e.message;}
  btn.disabled=false;
}
function clearFit(){
  LZ_DEF.forEach(z=>{layers[z.id]={on:false,vol:z.defVol,items:[]};});avData=null;
  document.getElementById('avbox').innerHTML=`<input type="file" id="avfile" accept="image/*" style="display:none" onchange="loadAv(event)"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/></svg><span>내 사진 업로드</span>`;
  document.getElementById('stagePerson').innerHTML='<div class="stage-ph">👤<br><span style="font-size:10px">내 사진<br>업로드</span></div>';
  document.getElementById('aiResult').className='airesult';
  renderLayerZones();
}

/* ════ PICKER ════ */
function openPK(zid){
  pkZone=zid;const z=LZM[zid];
  document.getElementById('pkTit').textContent=`${z.ico} ${z.lbl} — 옷 선택`;
  document.getElementById('pkSearch').value='';
  document.getElementById('pkModal').classList.add('open');renderPK();
}
function closePK(){document.getElementById('pkModal').classList.remove('open');pkZone=null;}
function renderPK(){
  const q=document.getElementById('pkSearch').value.toLowerCase();
  const z=LZM[pkZone];const already=new Set(layers[pkZone].items.map(c=>c.id));
  let list=q?clothes.filter(c=>c.name.toLowerCase().includes(q)||(c.colors||[]).some(cl=>cl.name.toLowerCase().includes(q))):clothes.filter(c=>z.cats.includes(c.cat));
  if(!list.length&&q)list=clothes.filter(c=>c.name.toLowerCase().includes(q));
  document.getElementById('pkList').innerHTML=list.length?list.map(c=>{
    const ci=CF[c.cat]||{ico:'👚'};const sel=already.has(c.id);
    const mainColor=(c.colors||[]).find(x=>x.role==='main');
    return`<div class="pk-item ${sel?'sel':''}" onclick="pickIt('${c.id}')">
      <div class="pk-thumb">${c.img?`<img src="${c.img}">`:`<span>${ci.ico}</span>`}</div>
      <div style="flex:1;min-width:0">
        <div class="pk-name">${c.name}</div>
        <div class="pk-sub">${ci.lbl}${mainColor?` · <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${mainColor.hex};vertical-align:middle;margin-right:2px"></span>${mainColor.name}`:''}</div>
      </div>
      ${sel?'<span class="pk-ck">✓</span>':''}
    </div>`;
  }).join(''):'<div style="padding:20px;text-align:center;color:var(--muted);font-size:12px;font-weight:500">해당 카테고리의 옷이 없어요</div>';
}
function pickIt(id){
  const c=clothes.find(x=>x.id===id);if(!c)return;
  const already=layers[pkZone].items.find(x=>x.id===id);
  if(already)layers[pkZone].items=layers[pkZone].items.filter(x=>x.id!==id);
  else{layers[pkZone].items.push(c);layers[pkZone].on=true;}
  renderPK();renderLayerZones();
}

/* ════ STATS ════ */
function renderStats(){
  const byCat={},bySea={},bySty={},byMat={};
  clothes.forEach(c=>{const ci=CF[c.cat]||{lbl:c.cat};byCat[ci.lbl]=(byCat[ci.lbl]||0)+1;if(c.season)bySea[c.season]=(bySea[c.season]||0)+1;if(c.style)bySty[c.style]=(bySty[c.style]||0)+1;if(c.material)byMat[c.material.split('(')[0]]=(byMat[c.material.split('(')[0]]||0)+1;});
  const tv=clothes.reduce((a,c)=>a+(Number(c.price)||0),0);
  const byColor={};clothes.forEach(c=>{(c.colors||[]).forEach(cl=>{if(cl.name)byColor[cl.name]=(byColor[cl.name]||0)+1;});});
  function bc(t,data,col){
    const max=Math.max(...Object.values(data),1);
    const rows=Object.entries(data).filter(([k])=>k).sort((a,b)=>b[1]-a[1]).slice(0,8);
    return`<div class="sc2"><div class="sc2t">${t}</div>${rows.map(([k,v])=>`<div class="brr"><div class="brl">${k}</div><div class="brt"><div class="brf" style="width:${Math.round(v/max*100)}%;background:${col}"></div></div><div class="brc">${v}</div></div>`).join('')}</div>`;
  }
  function bcColor(t,data){
    const max=Math.max(...Object.values(data),1);
    const rows=Object.entries(data).filter(([k])=>k).sort((a,b)=>b[1]-a[1]).slice(0,8);
    return`<div class="sc2"><div class="sc2t">${t}</div>${rows.map(([k,v])=>{const hex=getHex(k);return`<div class="brr"><div class="brl" style="display:flex;align-items:center;gap:5px"><span style="width:10px;height:10px;border-radius:50%;background:${hex};flex-shrink:0;border:1px solid rgba(0,0,0,.1)"></span>${k}</div><div class="brt"><div class="brf" style="width:${Math.round(v/max*100)}%;background:${hex}"></div></div><div class="brc">${v}</div></div>`;}).join('')}</div>`;
  }
  document.getElementById('statsGrid').innerHTML=`
    <div class="sc2"><div class="sc2t">전체 요약</div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px">
        ${[['총 아이템',clothes.length+'개'],['총 가치','₩'+Math.round(tv/1000)+'K'],['평균 단가','₩'+Math.round((clothes.length?tv/clothes.length:0)/1000)+'K'],['카테고리',Object.keys(byCat).length+'종']].map(([l,v])=>`<div style="background:var(--surface);border-radius:var(--r);padding:10px;border:1px solid var(--border)"><div style="font-size:19px;font-weight:700">${v}</div><div style="font-size:10px;color:var(--muted);margin-top:2px;font-weight:500">${l}</div></div>`).join('')}
      </div>
    </div>
    ${bc('카테고리별',byCat,'#7C3AED')}
    ${bc('계절별',bySea,'#0891B2')}
    ${bc('스타일별',bySty,'#D97706')}
    ${bc('소재별',byMat,'#059669')}
    ${bcColor('색상별 (복수 색상 포함)',byColor)}
  `;
}

/* ════ INIT ════ */
load();
goPage('home');
</script>
